{
  "name": "wdio-utils",
  "type": "module",
  "scripts": {
    "devices": "xcrun simctl list | egrep Booted",
    "knip": "npx knip --include=files --include exports,nsExports,types,nsTypes,enumMembers,duplicates",
    "lint": "npx eslint 'src/**/*.ts'",
    "lint:fix": "npx eslint 'src/**/*.ts' --fix",
    "prepare": "husky",
    "prettier:check": "prettier --config .prettierrc 'src/**/*.ts' --check --list-different",
    "prettier:write": "prettier --config .prettierrc 'src/**/*.ts' --write --list-different",
    "test": "npx wdio ./src/config/wdio.local.conf.ts"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "npm run prettier:write",
      "npx eslint"
    ],
    "package.json": [
      "npx sort-package-json"
    ]
  },
  "dependencies": {
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.4",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/axios-curlirize": "^1.3.5",
    "@types/eslint": "^9.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/dot-reporter": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/json-reporter": "^9.20.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/sauce-service": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "appium-xcuitest-driver": "^11.0.0",
    "axios": "^1.15.0",
    "axios-curlirize": "^2.0.0",
    "chai": "^6.2.2",
    "eslint": "^10.2.0",
    "eslint-plugin-chai-friendly": "^1.2.0",
    "eslint-plugin-mocha": "^11.2.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "expect-webdriverio": "^5.6.5",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "npm-failsafe": "^1.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "sort-package-json": "^3.6.1",
    "tsx": "^4.21.0",
    "wdio-json-reporter": "^4.0.1",
    "wdio-wait-for": "^3.1.1"
  },
  "knip": {
    "entry": [
      "src/config/wdio.*.ts",
      "src/specs/*.spec.ts",
      "src/specs/**/*.spec.ts"
    ],
    "ignore": [],
    "ignoreDependencies": [
      "chai",
      "deepmerge",
      "@wdio/globals"
    ]
  }
}
