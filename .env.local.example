# GitHub API token for API testing
GITHUB_TOKEN="your-github-personal-access-token"

# Sauce Labs credentials (for remote testing)
SAUCE_KEY="your-sauce-labs-key"
SAUCE_USER="your-sauce-labs-username"
SAUCE_REGION="us"

# iOS device configuration
IOS_UDID="your-ios-simulator-udid"
IOS_DEVICE_NAME="iPhone 15 Pro"
IOS_PLATFORM_VERSION="17.0"

# Android device configuration
ANDROID_UDID="your-android-emulator-udid"
ANDROID_DEVICE_NAME="Pixel 7"
ANDROID_PLATFORM_VERSION="14.0"

# Specify which specs to run (comma-separated). If empty, all specs from base config will run.
# Example with multiple specs: TEST_SPECS="example.spec.ts,another.spec.ts"
# Example with one spec: TEST_SPECS="example.spec.ts"
TEST_SPECS=""

# Mobile platform: ios or android
MOBILE_PLATFORM="ios"

# Environment key
ENV_KEY="dev"

# Whether to run in Sauce Labs or locally
IS_SAUCELABS=false

# CLI log level: trace | debug | info | warn | error | silent
CLI_LOG_LVL="error"
